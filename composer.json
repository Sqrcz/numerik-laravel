{
  "name": "slashlab/numerik-laravel",
  "description": "Laravel validation rules for Polish identification numbers (PESEL, NIP, REGON, KRS) — powered by slashlab/numerik.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "pesel",
    "nip",
    "regon",
    "krs",
    "poland",
    "polish",
    "laravel",
    "validation",
    "numerik"
  ],
  "authors": [
    {
      "name": "Sqrcz",
      "role": "Developer",
      "homepage": "https://github.com/sqrcz"
    }
  ],
  "require": {
    "php": "^8.3",
    "slashlab/numerik": "^1.0",
    "illuminate/validation": "^10.0 || ^11.0 || ^12.0 || ^13.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpunit/phpunit": "^12.0",
    "orchestra/testbench": "^8.0 || ^9.0 || ^10.0 || ^11.0"
  },
  "autoload": {
    "psr-4": {
      "SlashLab\\NumerikLaravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SlashLab\\NumerikLaravel\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "SlashLab\\NumerikLaravel\\NumerikServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml",
    "stan": "phpstan analyse --memory-limit=512M",
    "cs-fix": "php-cs-fixer fix",
    "cs-check": "php-cs-fixer fix --dry-run --diff",
    "check": [
      "@cs-check",
      "@stan",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {}
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
